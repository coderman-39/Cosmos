# ─────────────────────────────────────────────────────────────────────────────
# COSMOS configuration example.
# NOTE: the live file must be at  backend/.env  (that's what the app loads):
#     cp .env.example backend/.env
# Only OPENAI_API_KEY is required — everything else is optional.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI (required) ────────────────────────────────────────────────────────
# platform.openai.com › API keys. Powers the agent, fast paths, scanning,
# self-patching (Mutate) and embeddings.
OPENAI_API_KEY=
# Optional: point at a compatible gateway/proxy instead of api.openai.com.
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Models (optional — sensible defaults) ────────────────────────────────────
# FRIDAY_AGENT_MODEL=gpt-5.6            # main agent reasoning
# FRIDAY_FAST_MODEL=gpt-5.6-mini        # quick reads / routing / summaries
# FRIDAY_AGENT_FALLBACKS=gpt-5.6-mini   # tried in order when the primary fails
# FRIDAY_FAST_FALLBACKS=
# FRIDAY_REASONING_EFFORT=default       # low | medium | high for reasoning models
# FRIDAY_EMBED_MODEL=text-embedding-3-small

# ── Voice — ElevenLabs (optional; falls back to the macOS `say` voice) ───────
# elevenlabs.io › Profile → key. Voice ID: a voice's "..." menu › Copy Voice ID.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── You (optional — personalises prompts, Slack, dossier) ────────────────────
USER_NAME=
USER_FIRST_NAME=
USER_EMAIL=
USER_SLACK_HANDLE=

# ── Slack bridge (optional — drive COSMOS from a Slack channel) ──────────────
# Create an app from backend/slack-app-manifest.yaml (Socket Mode). Bot token
# xoxb-, app-level token xapp- with connections:write.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_BRIDGE_CHANNEL=
SLACK_BRIDGE_OWNER=
# Optional user token (xoxp-, users.profile:write) for reliable status updates.
SLACK_USER_TOKEN=

# ── Google Workspace (optional — Gmail / Calendar tools) ─────────────────────
# OAuth desktop-app credentials + a refresh token for your account.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Home location (optional — weather + "commute home" style asks) ───────────
# HOME_LAT=
# HOME_LON=
# HOME_LABEL=Home

# ── Reliability & performance knobs (defaults are good; uncomment to tune) ───
# FRIDAY_TOOL_TIMEOUT=90          # per-tool ceiling seconds
# FRIDAY_CONFIRM_TIMEOUT=180      # unanswered confirm auto-declines after this
# FRIDAY_ASK_TIMEOUT=300          # unanswered ask_user returns no-answer after this
# FRIDAY_RUN_TOKEN_BUDGET=500000  # cumulative token stop per run
# FRIDAY_CONNECT_TIMEOUT=5        # LLM TCP connect
# FRIDAY_STREAM_READ_TIMEOUT=15   # gap between stream chunks before failover
# FRIDAY_REQUEST_TIMEOUT=45       # whole-call cap for non-streaming LLM calls
# FRIDAY_PREWARM=1                # boot-time LLM + TTS cache warmup
# FRIDAY_HOST=127.0.0.1           # NEVER expose beyond localhost: no auth on the API
